generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  password    String?
  image       String?
  role        String   @default("USER") // USER | ADMIN
  points      Int      @default(0)
  passwordSet Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts         Post[]
  likes         Like[]
  comments      Comment[]
  accounts      Account[]
  sessions      Session[]

  // Contest
  contestOrganizer      ContestOrganizer?
  organizedContests     Contest[]           @relation("ContestOrganizer")
  contestParticipations ContestParticipant[]
  contestSubmissions    ContestSubmission[]

  // Group
  ownedGroups      Group[]       @relation("GroupOwner")
  groupMemberships GroupMember[]
  groupPosts       GroupPost[]
  groupMessages    GroupMessage[]
  sentInvites      GroupInvite[] @relation("SentInvites")

  // Rivals
  rivals   Rival[] @relation("UserRivals")
  rivalOf  Rival[] @relation("UserRivalOf")

  // Point history
  pointHistory PointHistory[]

  // Problems
  problems         Problem[]           @relation("UserProblems")
  problemSubs      ProblemSubmission[] @relation("UserProblemSubs")
  problemSolutions ProblemSolution[]   @relation("UserProblemSols")
  problemBookmarks ProblemBookmark[]
  difficultyVotes  DifficultyVote[]
  solutionComments SolutionComment[]   @relation("UserSolComments")
  problemSets      ProblemSet[]        @relation("UserProblemSets")
  contestContributions ContestContributor[] @relation("ContestContributors")
  essaySubmissions     ContestEssaySubmission[]
  problemEssaySubs     ProblemEssaySubmission[]

  // Chat & Notifications
  contestChats     ContestChat[]
  contestTeamChats ContestTeamChat[]
  notifications    Notification[]

  // Study sessions
  studySessions StudySession[]

  // Marathon
  marathonSessions MarathonSession[]

  // Duel
  challengerDuels Duel[] @relation("DuelChallenger")
  challengedDuels Duel[] @relation("DuelChallenged")

  // Team contests
  teamMemberships ContestTeamMember[]
  ledTeams        ContestTeam[]       @relation("TeamLeader")

  // Boards
  ownedBoards      Board[]       @relation("BoardOwner")
  boardMemberships BoardMember[]

  // Shop
  shopPoints         Int                @default(0)
  streakShieldsOwned Int                @default(0)
  streakShields      StreakShieldUsage[]
  userBanners        UserBanner[]

  // Badges
  selectedBadgeIds  String   @default("[]") // JSON array of badge IDs to display
  selectedTitleId   String?               // badge ID of selected title
  userBadges        UserBadge[]

  // Hidden badge tracking
  profileViewCount  Int      @default(0)  // 이 유저가 타인 프로필을 조회한 횟수 (변태 뱃지)

  @@map("users")
}

model AllowedEmail {
  id        String    @id @default(cuid())
  email     String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("allowed_emails")
}

model Post {
  id            String    @id @default(cuid())
  postNumber    Int?      @unique
  title         String
  content       String
  subject       String
  unit          String?
  type          String    @default("PROBLEM")
  imageUrls     String    @default("[]")
  fileUrls      String    @default("[]")
  pointsAwarded Int       @default(0)
  pinned        Boolean   @default(false)
  authorId      String
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes         Like[]
  comments      Comment[]
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("posts")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  postId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

// ───────────────────────────── Contest ─────────────────────────────

model Contest {
  id            String   @id @default(cuid())
  title         String
  description   String
  rules         String   @default("")
  status        String   @default("DRAFT") // DRAFT | PENDING | APPROVED | ONGOING | ENDED
  startTime     DateTime?
  durationMin   Int      @default(120)
  prize1        Int?
  prize2        Int?
  prize3        Int?
  prizesAwarded Boolean  @default(false)
  teamContest   Boolean  @default(false)
  teamSize      Int      @default(1)
  organizerId   String
  organizer     User     @relation("ContestOrganizer", fields: [organizerId], references: [id])
  problems      ContestProblem[]
  participants  ContestParticipant[]
  contributors  ContestContributor[]
  chats         ContestChat[]
  teams         ContestTeam[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("contests")
}

model ContestProblem {
  id           String  @id @default(cuid())
  contestId    String
  contest      Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  label        String  // A, B, C ...
  title        String
  content      String
  answer       String
  extraAnswers String  @default("[]") // JSON array of additional correct answers
  subAnswers   String  @default("[]") // JSON array of {label, answer, extra?} for multi-part problems
  points       Int     @default(100)
  imageUrls    String  @default("[]")
  order        Int     @default(0)
  allowRetry   Boolean @default(true)
  isEssay      Boolean @default(false) // 서술형 답안 여부
  submissions  ContestSubmission[]
  essaySubmissions ContestEssaySubmission[]

  @@map("contest_problems")
}

model ContestEssaySubmission {
  id        String   @id @default(cuid())
  problemId String
  userId    String
  content   String   @default("")
  imageUrls String   @default("[]")
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  problem   ContestProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([problemId, userId])
  @@map("contest_essay_submissions")
}

model ContestChat {
  id        String   @id @default(cuid())
  contestId String
  authorId  String
  content   String
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("contest_chats")
}

model ContestParticipant {
  id        String   @id @default(cuid())
  contestId String
  userId    String
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int      @default(0)
  joinedAt  DateTime @default(now())

  @@unique([contestId, userId])
  @@map("contest_participants")
}

model ContestSubmission {
  id        String   @id @default(cuid())
  problemId String
  userId    String
  answer    String
  correct   Boolean  @default(false)
  problem   ContestProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([problemId, userId])
  @@map("contest_submissions")
}

model ContestOrganizer {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now())

  @@map("contest_organizers")
}

// ───────────────────────────── Group ─────────────────────────────

model Group {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  avatar      String?
  isPublic    Boolean  @default(true)
  ownerId     String
  owner       User     @relation("GroupOwner", fields: [ownerId], references: [id])
  members     GroupMember[]
  posts       GroupPost[]
  messages    GroupMessage[]
  invites     GroupInvite[]
  problemSets ProblemSet[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("groups")
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String   @default("MEMBER") // MEMBER | ADMIN
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupPost {
  id        String   @id @default(cuid())
  groupId   String
  authorId  String
  title     String
  content   String
  imageUrls String   @default("[]") // JSON array of image URLs
  fileUrls  String   @default("[]") // JSON array of PDF/file URLs
  links     String   @default("[]") // JSON array of {label, url} objects
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("group_posts")
}

model GroupMessage {
  id        String    @id @default(cuid())
  groupId   String
  authorId  String
  content   String
  imageUrl  String?
  deletedAt DateTime?
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@map("group_messages")
}

model GroupInvite {
  id           String   @id @default(cuid())
  groupId      String
  invitedEmail String
  invitedBy    String
  status       String   @default("PENDING") // PENDING | ACCEPTED | DECLINED
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter      User     @relation("SentInvites", fields: [invitedBy], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([groupId, invitedEmail])
  @@map("group_invites")
}

// ───────────────────────────── Problems ─────────────────────────────

model Problem {
  id            String   @id @default(cuid())
  problemNumber Int      @unique
  title         String
  content       String
  answer        String
  extraAnswers  String   @default("[]") // JSON array of additional correct answers
  subAnswers    String   @default("[]") // JSON array of {label, answer, extra?} for multi-part problems
  imageUrls     String   @default("[]")
  subject       String?
  authorId      String
  requestedPts  Int      @default(0)
  approvedPts   Int?
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED
  contestId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  isEssay       Boolean  @default(false)
  allowRetry    Boolean  @default(true)

  author      User                       @relation("UserProblems", fields: [authorId], references: [id], onDelete: Cascade)
  submissions ProblemSubmission[]
  solutions   ProblemSolution[]
  setItems    ProblemSetItem[]
  essaySubmissions ProblemEssaySubmission[]
  bookmarks        ProblemBookmark[]
  difficultyVotes  DifficultyVote[]
  marathonItems    MarathonItem[]

  @@map("problems")
}

model ProblemBookmark {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@map("problem_bookmarks")
}

model DifficultyVote {
  id         String   @id @default(cuid())
  userId     String
  problemId  String
  difficulty Int      // 1~5
  createdAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@map("difficulty_votes")
}

model ProblemSubmission {
  id        String   @id @default(cuid())
  problemId String
  userId    String
  answer    String
  correct   Boolean  @default(false)
  wrongCount Int     @default(0)  // 오답 누적 횟수 (병 GOD 뱃지)
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user      User     @relation("UserProblemSubs", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([problemId, userId])
  @@map("problem_submissions")
}

model ProblemSolution {
  id        String            @id @default(cuid())
  problemId String
  authorId  String
  content   String
  imageUrls String            @default("[]")
  problem   Problem           @relation(fields: [problemId], references: [id], onDelete: Cascade)
  author    User              @relation("UserProblemSols", fields: [authorId], references: [id], onDelete: Cascade)
  comments  SolutionComment[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("problem_solutions")
}

model SolutionComment {
  id         String          @id @default(cuid())
  solutionId String
  authorId   String
  content    String
  solution   ProblemSolution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  author     User            @relation("UserSolComments", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@map("solution_comments")
}

model ProblemSet {
  id          String           @id @default(cuid())
  title       String
  description String           @default("")
  imageUrl    String?
  isPublic    Boolean          @default(true)
  authorId    String
  groupId     String?
  author      User             @relation("UserProblemSets", fields: [authorId], references: [id], onDelete: Cascade)
  group       Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  items       ProblemSetItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("problem_sets")
}

model ProblemSetItem {
  id        String     @id @default(cuid())
  setId     String
  problemId String
  order     Int        @default(0)
  set       ProblemSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  problem   Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([setId, problemId])
  @@map("problem_set_items")
}

model ContestContributor {
  id        String  @id @default(cuid())
  contestId String
  userId    String
  role      String  @default("CONTRIBUTOR") // CONTRIBUTOR | REVIEWER
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user      User    @relation("ContestContributors", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@map("contest_contributors")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // ADMIN_NOTICE | RIVAL_SOLVED | PROBLEM_APPROVED
  title     String
  content   String
  link      String?
  read      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model SystemConfig {
  key   String @id
  value String

  @@map("system_config")
}

model PermissionRequest {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  message   String?
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt DateTime @default(now())

  @@map("permission_requests")
}

model ProblemEssaySubmission {
  id        String   @id @default(cuid())
  problemId String
  userId    String
  content   String   @default("")
  imageUrls String   @default("[]")
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([problemId, userId])
  @@map("problem_essay_submissions")
}

model StudySession {
  id        String   @id @default(cuid())
  userId    String
  duration  Int      // seconds
  date      String   // YYYY-MM-DD (KST)
  subject   String?  // 과목 태그 (선택)
  memo      String?  // 세션 메모 (선택)
  startedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("study_sessions")
}

model ContestTeam {
  id          String   @id @default(cuid())
  contestId   String
  name        String
  description String   @default("")
  leaderId    String
  score       Int      @default(0)
  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  leader      User     @relation("TeamLeader", fields: [leaderId], references: [id])
  members     ContestTeamMember[]
  chats       ContestTeamChat[]
  createdAt   DateTime @default(now())

  @@unique([contestId, name])
  @@map("contest_teams")
}

model ContestTeamChat {
  id        String      @id @default(cuid())
  teamId    String
  authorId  String
  content   String
  team      ContestTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@map("contest_team_chats")
}

model ContestTeamMember {
  id       String      @id @default(cuid())
  teamId   String
  userId   String
  team     ContestTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime    @default(now())

  @@unique([teamId, userId])
  @@map("contest_team_members")
}

// ───────────────────────────── Board (FigJam-style whiteboard) ─────────────────────────────

model Board {
  id          String        @id @default(cuid())
  name        String
  description String        @default("")
  coverImage  String?
  isPublic    Boolean       @default(true)
  ownerId     String
  owner       User          @relation("BoardOwner", fields: [ownerId], references: [id])
  members     BoardMember[]
  elements    BoardElement[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("boards")
}

model BoardMember {
  id      String @id @default(cuid())
  boardId String
  userId  String
  role    String @default("EDITOR") // VIEWER | EDITOR | ADMIN
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([boardId, userId])
  @@map("board_members")
}

model BoardElement {
  id        String   @id @default(cuid())
  boardId   String
  type      String   // IMAGE | TEXT | STICKY | SHAPE | ARROW
  x         Float
  y         Float
  width     Float    @default(200)
  height    Float    @default(150)
  content   String   @default("")
  style     String   @default("{}")
  zIndex    Int      @default(0)
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("board_elements")
}

// ───────────────────────────── NextAuth ─────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Rival {
  id        String   @id @default(cuid())
  userId    String
  rivalId   String
  user      User     @relation("UserRivals", fields: [userId], references: [id], onDelete: Cascade)
  rival     User     @relation("UserRivalOf", fields: [rivalId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, rivalId])
  @@map("rivals")
}

// ───────────────────────────── Shop ─────────────────────────────

model StreakShieldUsage {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD — day that was protected
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@map("streak_shield_usages")
}

model BannerItem {
  id          String       @id @default(cuid())
  name        String
  description String       @default("")
  imageUrl    String
  price       Int
  size        String       @default("md") // "sm" | "md" | "lg"
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userBanners UserBanner[]

  @@map("banner_items")
}

model UserBanner {
  id           String     @id @default(cuid())
  userId       String
  bannerItemId String
  isEquipped   Boolean    @default(false)
  purchasedAt  DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bannerItem   BannerItem @relation(fields: [bannerItemId], references: [id], onDelete: Cascade)

  @@unique([userId, bannerItemId])
  @@map("user_banners")
}

// ───────────────────────────── Badges ─────────────────────────────

model Badge {
  id          String      @id @default(cuid())
  key         String      @unique // e.g. "solve_50", "hidden_first_ruby"
  name        String
  description String      @default("")
  imageUrl    String?
  title       String?     // 칭호 text shown next to username, null if no title
  isHidden    Boolean     @default(false)
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model PointHistory {
  id        String   @id @default(cuid())
  userId    String
  delta     Int
  reason    String
  subject   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_history")
}

// ───────────────────────────── Marathon ─────────────────────────────

model MarathonSession {
  id                     String         @id @default(cuid())
  userId                 String
  weekStart              String         // YYYY-MM-DD (KST Monday)
  completionBonusAwarded Boolean        @default(false)
  user                   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                  MarathonItem[]
  createdAt              DateTime       @default(now())

  @@unique([userId, weekStart])
  @@map("marathon_sessions")
}

model MarathonItem {
  id           String          @id @default(cuid())
  sessionId    String
  problemId    String
  order        Int             // 1-7 (난이도 오름차순)
  bonusPts     Int             @default(0)  // 클리어 시 지급 shopPoints
  solved       Boolean         @default(false)
  solvedAt     DateTime?
  bonusAwarded Boolean         @default(false)
  session      MarathonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  problem      Problem         @relation(fields: [problemId], references: [id])

  @@unique([sessionId, order])
  @@map("marathon_items")
}

// ───────────────────────────── Duel ─────────────────────────────

model Duel {
  id              String   @id @default(cuid())
  challengerId    String
  challengedId    String
  status          String   @default("PENDING") // PENDING | ACTIVE | FINISHED | DECLINED

  // Settings
  excludedSubjects String  @default("[]") // JSON array of SubjectKey
  difficulties     String  @default("[]") // JSON array of tier names
  problemCount     Int     @default(10)
  timeLimit        Int     @default(600)  // seconds
  allowSolved      Boolean @default(true) // 이미 푼 문제 포함 여부

  // Problems assigned on accept (JSON array of problem IDs)
  problems         String  @default("[]")
  startedAt        DateTime?
  endedAt          DateTime?

  // Scores
  challengerScore  Int     @default(0)
  challengedScore  Int     @default(0)
  winnerId         String? // null = draw
  winnerDeclared   Boolean @default(false)

  challenger    User             @relation("DuelChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  challenged    User             @relation("DuelChallenged", fields: [challengedId], references: [id], onDelete: Cascade)
  submissions   DuelSubmission[]

  createdAt     DateTime @default(now())

  @@map("duels")
}

model DuelSubmission {
  id        String   @id @default(cuid())
  duelId    String
  userId    String
  problemId String
  correct   Boolean
  duel      Duel     @relation(fields: [duelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([duelId, userId, problemId])
  @@map("duel_submissions")
}
