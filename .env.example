# Database
DATABASE_URL="file:./data/minlluminati.db"

# NextAuth
# 로컬: http://localhost:3000
# Cloudflare Tunnel / ngrok: 터널 URL (예: https://abc.trycloudflare.com)
# 도메인 연결 후: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"
# 반드시 랜덤 문자열로 변경 (생성: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# Google OAuth (선택 - 구글 로그인 원하면 설정)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Admin email (초기 관리자 계정)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme123"

# 크론 보안 (외부에서 daily-penalty API 호출 시 사용)
CRON_SECRET="your-cron-secret-here"
